# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/dsa-master

# JWT secrets - generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth - https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Used to build absolute URLs (OAuth redirect, password reset links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Not yet wired up — needed if you want real password-reset / notification
# emails instead of the console.log stub in /api/auth/forgot-password.
# RESEND_API_KEY=
